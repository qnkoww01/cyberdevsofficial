        <!-- OFFICIAL CLIENT SECTION -->
        <div id="official-client" class="content-section ">
            <div class="banner-item client-layout">
                <div class="client-info">
                    <h1 class="xmas-title-style" style="font-size: 25px;">You Want Clean CS 1.6 VERSION?</h1>
                    <h2 class="xmas-gold-style" style="font-size: 20px; margin-top: 10px;">Download Our OFFICIAL Clean Client!</h2>
                    <p class="client-desc-text">
                        📌What Have Our Client:<br>
                        ✅ULTIMATEX STYLE<br>
                        ✅CLEAN SETTINGS<br>
                        ✅SMOOTH GAMEPLAY<br>
                        ✅BOOSTED FPS<br>
                        ✅STEAM VERSION<br>
