                </div>
                <div class="client-images">
                    <img src="U_STORE_OFFICIAL_CLIENT_IMG1.png" class="client-img-side" onclick="zoomImg(this.src)" onerror="this.src='https://via.placeholder.com/250x180?text=Client+Preview'">
                    <img src="U_STORE_OFFICIAL_CLIENT_IMG2.png" class="client-img-side" onclick="zoomImg(this.src)" onerror="this.src='https://via.placeholder.com/250x180?text=Client+Preview+2'">
                </div>
            </div>
        </div>

        <!-- TECH SUPPORT SECTION -->
        <div id="tech-support" class="content-section ">
            <h2 class="xmas-title-style" style="font-size: 50px; margin-bottom: 30px;">Technical Support</h2>
            <div style="text-align: center; padding: 40px; max-width: 800px; margin: 0 auto;">
                <i class="fa-solid fa-headset" style="font-size: 80px; color: var(--neon-blue); text-shadow: 0 0 20px var(--neon-blue);"></i>
                <h3 style="font-family: 'Orbitron'; color: #fff; margin: 30px 0 20px 0; font-size: 28px;">Need Technical Assistance?</h3>
                <p style="color: #ccc; font-family: 'Rajdhani'; font-size: 18px; line-height: 1.8; margin-bottom: 30px;">
                    Our technical support team is here to help you with any issues.<br>
                    For the fastest response, please contact us via:
                </p>
                <div style="background: var(--bg-glass); border: 2px solid var(--neon-blue); border-radius: 12px; padding: 30px; margin-top: 30px;">
                    <h4 style="font-family: 'Orbitron'; color: var(--neon-blue); margin-bottom: 15px;">Official Email</h4>
                    <a href="mailto:ultimatexbusiness@gmail.com" style="color: #fff; font-family: 'Orbitron'; font-size: 20px; font-weight: 700; text-decoration: none;">
                        ultimatexbusiness@gmail.com
