    <!-- Account Modal -->
    <div id="account-modal" class="modal-overlay" onclick="closeAccountModal()">
        <div class="modal-content" onclick="event.stopPropagation()">
            <div class="modal-header">
                <div class="modal-title">👤 PERSONAL CABINET</div>
                <span class="modal-close" onclick="closeAccountModal()">×</span>
            </div>
            <div id="account-content" style="text-align: center; padding: 20px;">
                <!-- Login Form (shown when not logged in) -->
                <div id="login-form">
                    <i class="fa-solid fa-user-circle" style="font-size: 80px; color: var(--neon-blue); text-shadow: 0 0 20px var(--neon-blue);"></i>
                    <h3 style="font-family: 'Orbitron'; color: #fff; margin: 20px 0;">Login to Your Account</h3>
                    <p style="color: #999;">You can login with your Counter-Strike Account</p>
                    <input type="text" class="login-input" id="login-nickname" placeholder="Nickname">
                    <input type="password" class="login-input" id="login-password" placeholder="Password">
                    <button class="btn-buy-now" style="margin-top: 10px;" onclick="handleLogin()">
                        <i class="fa-solid fa-right-to-bracket"></i> Login
                    </button>
                </div>

                <!-- Account Info (shown when logged in) -->
                <div id="account-info" style="display: none;">
                    <i class="fa-solid fa-user-circle" style="font-size: 80px; color: var(--neon-blue); text-shadow: 0 0 20px var(--neon-blue);"></i>
                    <div class="account-info-display">
                        <div class="info-row">
                            <span class="info-label">Nickname:</span>
                            <span class="info-value" id="acc-nickname"></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Member Since:</span>
                            <span class="info-value" id="acc-member-since"></span>
                        </div>
                    </div>
                    <button class="btn-buy-now" style="margin-top: 20px;" onclick="handleLogout()">
                        <i class="fa-solid fa-right-from-bracket"></i> Logout
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Support Modal -->
    <div id="support-modal" class="modal-overlay" onclick="closeSupportModal()">
        <div class="modal-content" onclick="event.stopPropagation()">
            <div class="modal-header">
                <div class="modal-title">🎧 TECHNICAL SUPPORT</div>
                <span class="modal-close" onclick="closeSupportModal()">×</span>
            </div>
            <div style="text-align: center; padding: 20px;">
                <i class="fa-solid fa-headset" style="font-size: 80px; color: var(--neon-blue); text-shadow: 0 0 20px var(--neon-blue);"></i>
                <h3 style="font-family: 'Orbitron'; color: #fff; margin: 20px 0;">Do you have any Problem?</h3>
                <p style="color: #ccc; font-family: 'Rajdhani'; font-size: 16px;">
                    Write us a message in our official Email:<br>
                    <a href="mailto:ultimatexbusiness@gmail.com" style="color: var(--neon-blue); font-family: 'Orbitron'; font-weight: 700;">
                        ultimatexbusiness@gmail.com
                    </a>
                </p>
            </div>
        </div>
    </div>

    <script>
        // === SERVER STATUS TRACKING (SAME LOGIC AS TRACKING.HTML) ===

        // Update server status using tracking logic
        function updateServerStatus(serverId, serverType) {
            fetch("status.php?server=" + serverType + "&t=" + Date.now())
                .then(res => res.json())
                .then(data => {
                    const indicator = document.getElementById('status-indicator-' + serverId);
                    const statusText = document.getElementById('status-text-' + serverId);

                    if (data && data.online) {
                        // Server is ONLINE
                        indicator.classList.remove('loading', 'offline');
                        indicator.classList.add('online');

                        statusText.classList.remove('offline');
                        statusText.classList.add('online');
                        statusText.textContent = 'Online';
                    } else {
                        // Server is OFFLINE
                        indicator.classList.remove('loading', 'online');
                        indicator.classList.add('offline');

                        statusText.classList.remove('online');
                        statusText.classList.add('offline');
                        statusText.textContent = 'Offline';
                    }
                })
                .catch(e => {
                    console.error("Error checking server " + serverId, e);
                    // On error, show as offline
                    const indicator = document.getElementById('status-indicator-' + serverId);
                    const statusText = document.getElementById('status-text-' + serverId);

                    indicator.classList.remove('loading', 'online');
                    indicator.classList.add('offline');

                    statusText.classList.remove('online');
                    statusText.classList.add('offline');
                    statusText.textContent = 'Offline';
                });
        }

        // Auto refresh server status every 2 seconds (same as tracking)
        function autoRefreshServerStatus() {
            updateServerStatus(1, 'ultimatex'); // First server
            updateServerStatus(2, 'emcz'); // Second server
        }

        // Start auto refresh
        setInterval(autoRefreshServerStatus, 2000);
        autoRefreshServerStatus(); // Initial call

        // === REST OF THE ORIGINAL CODE ===

        // Privilege data for both servers
        const privilegesData = {
            zpux: [
                { value: 'viptest', text: 'ViP Test - €0.00', link: '', isTest: true },
                { value: 'vip', text: 'ViP - €1.99', link: 'https://paypal.com/vip' },
                { value: 'supervip', text: 'Super-ViP - €3.99', link: 'https://paypal.com/supervip' },
                { value: 'admin', text: 'Admin - €7.99', link: 'https://paypal.com/admin' },
                { value: 'megavip', text: 'Head-Admin - €12.99', link: 'https://paypal.com/headadmin' },
                { value: 'megaadmin', text: 'Owner - €19.99', link: 'https://paypal.com/owner' },
                { value: 'owner', text: 'Founder - €29.99', link: 'https://paypal.com/founder' },
                { value: 'battlepass', text: 'Battle Pass - €4.99 (Month)', link: 'https://paypal.com/battlepass' }
            ],
            emcz: [
                { value: 'vip', text: 'VIP - €2.99', link: 'https://paypal.com/emcz-vip' },
                { value: 'admin', text: 'ADMIN - €4.99', link: 'https://paypal.com/emcz-admin' },
                { value: 'boss', text: 'BOSS - €7.99', link: 'https://paypal.com/emcz-boss' },
                { value: 'epic', text: 'EPIC - €9.99', link: 'https://paypal.com/emcz-epic' },
                { value: 'ultra', text: 'ULTRA - €12.99', link: 'https://paypal.com/emcz-ultra' },
                { value: 'deluxe', text: 'DELUXE - €19.99', link: 'https://paypal.com/emcz-deluxe' },
                { value: 'owner', text: 'OWNER - €29.99', link: 'https://paypal.com/emcz-owner' },
                { value: 'founder', text: 'FOUNDER - €39.99', link: 'https://paypal.com/emcz-founder' },
                { value: 'battlepass', text: 'BATTLE PASS - €4.99 (Month)', link: 'https://paypal.com/emcz-battlepass' }
            ]
        };

        // Update privileges based on selected server
        function updatePrivileges() {
            const serverSelect = document.getElementById('server-select');
            const privilegeSelect = document.getElementById('privilege-select');
            const errorMsg = document.getElementById('privilege-error');

            const server = serverSelect.value;

            if (!server) {
                privilegeSelect.disabled = true;
                privilegeSelect.innerHTML = '<option value="">First choose server!</option>';
                errorMsg.style.display = 'block';
                return;
            }

            privilegeSelect.disabled = false;
            errorMsg.style.display = 'none';
            privilegeSelect.innerHTML = '<option value="">Choose privilege</option>';

            privilegesData[server].forEach(priv => {
                const option = document.createElement('option');
                option.value = priv.value;
                option.textContent = priv.text;
                option.setAttribute('data-link', priv.link);
                option.setAttribute('data-is-test', priv.isTest || false);
                privilegeSelect.appendChild(option);
            });

            // Reset button text when server changes
            updateButtonForPrivilege();
        }

        // Update button text and visibility based on privilege selection
        function updateButtonForPrivilege() {
            const privilegeSelect = document.getElementById('privilege-select');
            const selectedOption = privilegeSelect.options[privilegeSelect.selectedIndex];
            const isTest = selectedOption ? selectedOption.getAttribute('data-is-test') === 'true' : false;

            const purchaseBtn = document.getElementById('purchase-btn');
            const paymentGroup = document.getElementById('payment-method-group');
            const paymentSelect = document.getElementById('payment-select');
            const helpBtn = document.getElementById('help-btn');

            if (isTest) {
                // ViP Test selected
                purchaseBtn.innerHTML = '<i class="fas fa-check-circle"></i> Activate ViP Test<span class="vip-test-days">5 Days!</span>';
                purchaseBtn.classList.add('activate-btn');
                paymentGroup.style.display = 'none';
                paymentSelect.removeAttribute('required');
                helpBtn.style.display = 'none';
            } else {
                // Regular privilege selected
                purchaseBtn.innerHTML = '<i class="fas fa-shopping-cart"></i> Buy Now';
                purchaseBtn.classList.remove('activate-btn');
                paymentGroup.style.display = 'block';
                paymentSelect.setAttribute('required', 'required');
                helpBtn.style.display = 'block';
            }
        }

        // Listen to privilege changes
        document.addEventListener('DOMContentLoaded', function() {
            const privilegeSelect = document.getElementById('privilege-select');
            privilegeSelect.addEventListener('change', updateButtonForPrivilege);
        });

        // Handle purchase
        function handlePurchase(e) {
            e.preventDefault();

            const server = document.getElementById('server-select').value;
            const privilegeSelect = document.getElementById('privilege-select');
            const privilege = privilegeSelect.value;
            const nick = document.getElementById('nickname-input').value.trim();
            const pass = document.getElementById('password-input').value.trim();
            const payment = document.getElementById('payment-select').value;

            if (!server) {
                showNotification('Please select a server first!', 'error');
                return;
            }

            if (!privilege || !nick || !pass) {
                showNotification('Please fill all fields!', 'error');
                return;
            }

            // Check if ViP Test is selected
            const selectedOption = privilegeSelect.options[privilegeSelect.selectedIndex];
            const isTest = selectedOption.getAttribute('data-is-test') === 'true';

            if (isTest) {
                // Handle ViP Test activation
                activateVipTest(nick, pass, server);
            } else {
                // Handle regular purchase
                if (!payment || payment !== 'paypal') {
                    showNotification('Please select PayPal as payment method!', 'error');
                    return;
                }

                const paypalLink = selectedOption.getAttribute('data-link');

                // Save purchase data to localStorage (just locally for redirect)
                const purchaseData = {
                    nickname: nick,
                    password: pass,
                    privilege: selectedOption.textContent.split(' - ')[0],
                    server: server === 'zpux' ? 'Zombie Plague ULTIMATEX' : 'Eat Me Completely Zombie',
                    date: new Date().toISOString()
                };

                localStorage.setItem('pendingPurchase', JSON.stringify(purchaseData));

                // Open PayPal link
                window.open(paypalLink, '_blank');

                showNotification('Redirecting to PayPal...', 'success');
            }
        }

        // Activate ViP Test (sends request to PHP backend in same file)
        function activateVipTest(nickname, password, server) {
            // Show loading notification
            showNotification('Processing ViP Test activation...', 'info');

            // Send data to PHP backend (CURRENT FILE)
            fetch(window.location.href, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        action: 'activate_vip_test',
                        nickname: nickname,
                        password: password,
                        server: server
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showNotification('✅ ViP Test Activated Successfully!', 'success');

                        // Записване в локалния сторидж само за логин (Personal Cabinet)
                         const userData = {
                            nickname: nickname,
                            password: password,
                            memberSince: new Date().toLocaleDateString()
                        };
                         // Тук записваме само локално за да можеш да влезеш в акаунта си
                         let users = JSON.parse(localStorage.getItem('registeredUsers') || '[]');
                         users.push(userData);
                         localStorage.setItem('registeredUsers', JSON.stringify(users));

                        // Reset form
                        document.getElementById('purchase-form').reset();
                        updatePrivileges();
                    } else {
                        showNotification(data.message || 'Activation failed', 'error');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showNotification('Connection error. Please try again!', 'error');
                });
        }

        // Mobile Menu
        function toggleMobileMenu() {
            document.getElementById('sidebar').classList.toggle('mobile-open');
        }

        // Image Zoom
        function zoomImg(src) {
            document.getElementById('zoomed-image-src').src = src;
            document.getElementById('image-zoom-overlay').classList.add('active');
        }

        function closeZoom() {
            document.getElementById('image-zoom-overlay').classList.remove('active');
        }

        // Notification Modified for icons
        function showNotification(msg, type = 'success') {
            const notif = document.getElementById('notification-box');
            const notifText = notif.querySelector('.notif-text');
            const notifIcon = notif.querySelector('.notif-icon');

            notifText.textContent = msg;

            // Reset classes
            notifIcon.className = 'fa-solid notif-icon';
            notif.style.borderColor = 'var(--neon-blue)';
            notifIcon.style.color = 'var(--neon-blue)';

            if (type === 'error') {
                 notifIcon.classList.add('fa-circle-xmark');
                 notif.style.borderColor = 'var(--neon-red)';
                 notifIcon.style.color = 'var(--neon-red)';
            } else if (type === 'success') {
                notifIcon.classList.add('fa-circle-check');
                notif.style.borderColor = 'var(--neon-green)';
                notifIcon.style.color = 'var(--neon-green)';
            } else {
                 notifIcon.classList.add('fa-info-circle');
            }

            notif.classList.add('show');
            setTimeout(() => notif.classList.remove('show'), 3000);
        }

        // Copy IP
        function copyIP(ip) {
            navigator.clipboard.writeText(ip).then(() => {
                showNotification(`IP Copied!`, 'success');
            }).catch(() => {
                alert(`Copy this IP: ${ip}`);
            });
        }

        // Account Modal
        function openAccountModal() {
            document.getElementById('account-modal').classList.add('active');
            checkLoginStatus();
        }

        function closeAccountModal() {
            document.getElementById('account-modal').classList.remove('active');
        }

        function checkLoginStatus() {
            const loggedUser = localStorage.getItem('loggedUser');

            if (loggedUser) {
                const userData = JSON.parse(loggedUser);
                document.getElementById('login-form').style.display = 'none';
                document.getElementById('account-info').style.display = 'block';
                document.getElementById('acc-nickname').textContent = userData.nickname;
                document.getElementById('acc-member-since').textContent = userData.memberSince;
                document.getElementById('user-display-name').textContent = userData.nickname;
            } else {
                document.getElementById('login-form').style.display = 'block';
                document.getElementById('account-info').style.display = 'none';
                document.getElementById('user-display-name').textContent = 'No Account';
            }
        }

        function handleLogin() {
            const nickname = document.getElementById('login-nickname').value.trim();
            const password = document.getElementById('login-password').value.trim();

            if (!nickname || !password) {
                showNotification('Please fill all fields!', 'error');
                return;
            }

            // Get registered users from localStorage (Local Login logic)
            const users = JSON.parse(localStorage.getItem('registeredUsers') || '[]');
            const user = users.find(u => u.nickname === nickname && u.password === password);

            if (user) {
                localStorage.setItem('loggedUser', JSON.stringify(user));
                showNotification('Login successful!', 'success');
                checkLoginStatus();
            } else {
                showNotification('Invalid credentials!', 'error');
            }
        }

        function handleLogout() {
            localStorage.removeItem('loggedUser');
            showNotification('Logged out successfully!', 'success');
            checkLoginStatus();
            closeAccountModal();
        }

        // Personal Account Page functions
        function handleLoginPage() {
            const nickname = document.getElementById('login-nickname-page').value.trim();
            const password = document.getElementById('login-password-page').value.trim();

            if (!nickname || !password) {
                showNotification('Please fill all fields!', 'error');
                return;
            }

            const users = JSON.parse(localStorage.getItem('registeredUsers') || '[]');
            const user = users.find(u => u.nickname === nickname && u.password === password);

            if (user) {
                localStorage.setItem('loggedUser', JSON.stringify(user));
                showNotification('Login successful!', 'success');
                checkLoginStatusPage();
                checkLoginStatus();
            } else {
                showNotification('Invalid credentials!', 'error');
            }
        }

        function handleLogoutPage() {
            localStorage.removeItem('loggedUser');
            showNotification('Logged out successfully!', 'success');
            checkLoginStatusPage();
            checkLoginStatus();
        }

        function checkLoginStatusPage() {
            const loggedUser = localStorage.getItem('loggedUser');

            if (loggedUser) {
                const userData = JSON.parse(loggedUser);
                document.getElementById('login-form-page').style.display = 'none';
                document.getElementById('account-info-page').style.display = 'block';
                document.getElementById('acc-nickname-page').textContent = userData.nickname;
                document.getElementById('acc-member-since-page').textContent = userData.memberSince;
            } else {
                document.getElementById('login-form-page').style.display = 'block';
                document.getElementById('account-info-page').style.display = 'none';
            }
        }

        // Support Modal
        function openSupportModal() {
            document.getElementById('support-modal').classList.add('active');
        }

        function closeSupportModal() {
            document.getElementById('support-modal').classList.remove('active');
        }

        // Payment Help
        function showPaymentHelp() {
            showNotification('For Help Join Our Discord Community!', 'info');
        }

        // Download Client
        function handleDownload() {
            showNotification('Download starting...', 'info');
            setTimeout(() => {
                showNotification('Client Downloaded!', 'success');
            }, 2000);
        }

        // Load list from SERVER (VIP Test Testers with dates)
        function loadTestersList() {
             fetch(window.location.href, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action: 'get_vip_test_Testers' })
            })
            .then(res => res.json())
            .then(Testers => {
                const tbody = document.getElementById('Testers-table-body');

                if (!Testers || Testers.length === 0) {
                     tbody.innerHTML = '<tr><td colspan="4" style="text-align: center; color: #999;">No VIP Test activations yet</td></tr>';
                     return;
                }

                tbody.innerHTML = Testers.map(tester => `
                    <tr>
                        <td>
                            <div class="player-info">
                                <div class="acc-logo">
                                    <i class="fa-solid fa-user"></i>
                                </div>
                                <span class="player-name">${tester.nickname}</span>
                            </div>
                        </td>
                        <td>${tester.privilege}</td>
                        <td><span class="server-badge">${tester.server}</span></td>
                        <td>${tester.date}</td>
                    </tr>
                `).join('');
            })
            .catch(err => console.error("Error loading Testers:", err));
        }

        // Initialize
        window.addEventListener('load', () => {
            console.log('%cULTIMATEX® COMMUNITY', 'color: #00f3ff; font-size: 30px; font-weight: bold;');
            loadTestersList();
            checkLoginStatus();
            checkLoginStatusPage();
        });

        // ESC to close
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeAccountModal();
                closeSupportModal();
                closeZoom();
            }
        });
    </script>
</body>

</html>