<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>ULTIMATEX® COMMUNITY</title>
    <link rel="icon" type="image/png" href="https://i.imgur.com/wDGEyA0.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

    <!-- External Libraries -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;700;900&family=Orbitron:wght@700;900&display=swap" rel="stylesheet">

    <style>
        :root {
            /* NEON BLUE RAINBOW PALETTE */
            --neon-blue: #00f3ff;
            --deep-blue: #0066ff;
            --neon-purple: #bc13fe;
            --neon-pink: #ff006e;
            --neon-green: #39ff14;
            --neon-yellow: #ffff00;
            --neon-red: #ff0000;
            --bg-dark: #020205;
            --bg-glass: rgba(0, 10, 30, 0.85);
            --space-bg: radial-gradient(circle at center, #0b1026 0%, #000000 100%);
            --sidebar-bg: rgba(5, 10, 20, 0.95);
        }

        /* === GLOBAL RESET === */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Rajdhani', sans-serif;
            user-select: none;
        }

        body {
            min-height: 100vh;
            background: var(--space-bg);
            color: #fff;
            overflow-x: hidden;
        }

        /* === ANIMATIONS === */
        @keyframes neonPulse {
            0% { text-shadow: 0 0 10px var(--neon-blue), 0 0 20px var(--neon-blue); }
            50% { text-shadow: 0 0 20px var(--neon-blue), 0 0 40px var(--deep-blue), 0 0 60px var(--neon-purple); }
            100% { text-shadow: 0 0 10px var(--neon-blue), 0 0 20px var(--neon-blue); }
        }

        @keyframes flowingNeon {
            0% { border-color: var(--neon-blue); box-shadow: 0 0 10px rgba(0, 243, 255, 0.4); }
            33% { border-color: var(--deep-blue); box-shadow: 0 0 15px rgba(0, 102, 255, 0.6); }
            66% { border-color: var(--neon-purple); box-shadow: 0 0 10px rgba(188, 19, 254, 0.4); }
            100% { border-color: var(--neon-blue); box-shadow: 0 0 10px rgba(0, 243, 255, 0.4); }
        }

        @keyframes rainbowGlow {
            0% { box-shadow: 0 0 20px var(--neon-blue); }
            20% { box-shadow: 0 0 20px var(--neon-green); }
            40% { box-shadow: 0 0 20px var(--neon-yellow); }
            60% { box-shadow: 0 0 20px var(--neon-pink); }
            80% { box-shadow: 0 0 20px var(--neon-purple); }
            100% { box-shadow: 0 0 20px var(--neon-blue); }
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes slideDown {
            from { transform: translateY(-100%); }
            to { transform: translateY(0); }
        }

        @keyframes pulse-blue {
            0% { box-shadow: 0 0 5px rgba(0, 243, 255, 0.3); }
            50% { box-shadow: 0 0 20px rgba(0, 243, 255, 0.6); }
            100% { box-shadow: 0 0 5px rgba(0, 243, 255, 0.3); }
        }

        @keyframes pulse-green {
            0% { box-shadow: 0 0 10px rgba(57, 255, 20, 0.6); }
            50% { box-shadow: 0 0 25px rgba(57, 255, 20, 0.9); }
            100% { box-shadow: 0 0 10px rgba(57, 255, 20, 0.6); }
        }

        @keyframes pulse-red {
            0% { box-shadow: 0 0 10px rgba(255, 0, 0, 0.6); }
            50% { box-shadow: 0 0 25px rgba(255, 0, 0, 0.9); }
            100% { box-shadow: 0 0 10px rgba(255, 0, 0, 0.6); }
        }

        @keyframes moveGradient {
            0% { background-position: 0% 50%; }
            100% { background-position: 100% 50%; }
        }

        /* === HEADER === */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            padding: 14px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            background: rgba(0, 5, 15, 0.95);
            backdrop-filter: blur(17px);
            border-bottom: 3px solid var(--neon-blue);
            box-shadow: 0 5px 25px rgba(0, 243, 255, 0.3);
            animation: flowingNeon 6s infinite linear;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 22px;
        }

        .menu-toggle {
            font-size: 23px;
            color: #fff;
            cursor: pointer;
            display: none;
        }

        .store-logo {
            font-family: 'Orbitron', sans-serif;
            font-size: 22px;
            font-weight: 900;
            color: #fff;
            text-shadow: 0 0 10px var(--neon-blue), 0 0 20px var(--deep-blue);
            letter-spacing: 2px;
            animation: neonPulse 3s ease-in-out infinite;
        }

        .header-announcement {
            background: linear-gradient(90deg, var(--neon-blue), var(--deep-blue), var(--neon-blue));
            background-size: 200% 100%;
            animation: moveGradient 3s linear infinite;
            color: #000;
            padding: 8px 20px;
            border-radius: 25px;
            font-weight: 700;
            font-size: 13px;
            font-family: 'Orbitron';
            box-shadow: 0 3px 10px rgba(0, 243, 255, 0.4);
        }

        .header-controls {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 15px;
            background: rgba(0, 243, 255, 0.1);
            border: 2px solid var(--neon-blue);
            border-radius: 25px;
            cursor: pointer;
            transition: all 0.3s ease;
            animation: pulse-blue 3s ease infinite;
        }

        .user-info:hover {
            background: rgba(0, 243, 255, 0.2);
            box-shadow: 0 0 15px var(--neon-blue);
            transform: translateY(-2px);
        }

        .user-avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            border: 2px solid var(--neon-blue);
        }

        .user-name {
            font-weight: 600;
            color: var(--neon-blue);
            font-family: 'Orbitron';
        }

        .badge-online {
            width: 10px;
            height: 10px;
            background: var(--neon-green);
            border-radius: 50%;
            animation: rainbowGlow 2s ease infinite;
        }

        /* === SIDEBAR === */
        .sidebar {
            position: fixed;
            left: 0;
            top: 70px;
            width: 220px;
            height: calc(100vh - 70px);
            background: var(--sidebar-bg);
            border-right: 2px solid var(--neon-blue);
            padding: 20px 0;
            z-index: 900;
            overflow-y: auto;
            animation: slideDown 0.6s ease;
            box-shadow: 5px 0 20px rgba(0, 243, 255, 0.2);
        }

        .sidebar::-webkit-scrollbar {
            width: 6px;
        }

        .sidebar::-webkit-scrollbar-track {
            background: var(--bg-dark);
        }

        .sidebar::-webkit-scrollbar-thumb {
            background: var(--neon-blue);
            border-radius: 3px;
        }

        .sidebar-section {
            margin-bottom: 25px;
        }

        .sidebar-title {
            padding: 10px 20px;
            font-size: 11px;
            font-weight: 700;
            color: #666;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-family: 'Orbitron';
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px;
            color: #999;
            text-decoration: none;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            font-family: 'Rajdhani';
            font-weight: 600;
        }

        .nav-item::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            width: 3px;
            background: var(--neon-blue);
            transform: scaleY(0);
            transition: transform 0.3s ease;
        }

        .nav-item:hover::before,
        .nav-item.active::before {
            transform: scaleY(1);
        }

        .nav-item:hover,
        .nav-item.active {
            background: rgba(0, 243, 255, 0.1);
            color: var(--neon-blue);
            text-shadow: 0 0 10px var(--neon-blue);
        }

        .nav-item i {
            font-size: 16px;
            width: 20px;
        }

        .nav-badge {
            margin-left: auto;
            background: var(--neon-blue);
            color: #000;
            padding: 3px 9px;
            border-radius: 9px;
            font-size: 9px;
            font-weight: 800;
            font-family: 'Orbitron';
        }

        .nav-badge.new {
            background: var(--neon-pink);
            animation: rainbowGlow 4s ease infinite;
        }

        /* === MAIN CONTENT === */
        .main-content {
            margin-left: 250px;
            margin-top: 70px;
            padding: 60px;
            min-height: calc(100vh - 80px);
        }

        .content-section {
            display: none;
            animation: fadeIn 0.5s ease;
        }

        .content-section.active {
            display: block;
        }

        /* === WELCOME BANNER === */
        .welcome-banner {
            background: linear-gradient(135deg, var(--neon-blue) 0%, var(--deep-blue) 100%);
            padding: 25px 30px;
            border-radius: 12px;
            margin-bottom: 30px;
            box-shadow: 0 8px 25px rgba(0, 243, 255, 0.4);
            border: 2px solid var(--neon-blue);
            animation: flowingNeon 4s infinite linear;
        }

        .welcome-text {
            font-size: 18px;
            font-weight: 700;
            color: #000;
            margin-bottom: 5px;
            font-family: 'Orbitron';
        }

        .welcome-subtext {
            font-size: 14px;
            color: rgba(0, 0, 0, 0.8);
            font-family: 'Rajdhani';
        }

        /* === PURCHASE CONTAINER === */
        .purchase-container {
            display: grid;
            grid-template-columns: 1fr 450px;
            gap: 30px;
        }

        .purchase-form-card {
            background: var(--bg-glass);
            border: 2px solid var(--neon-blue);
            border-radius: 12px;
            padding: 30px;
            box-shadow: 0 5px 20px rgba(0, 243, 255, 0.3);
            animation: flowingNeon 5s infinite linear;
        }

        .form-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 2px solid rgba(0, 243, 255, 0.3);
        }

        .form-header i {
            font-size: 24px;
            color: var(--neon-blue);
            text-shadow: 0 0 10px var(--neon-blue);
        }

        .form-title {
            font-size: 22px;
            font-weight: 700;
            color: var(--neon-blue);
            font-family: 'Orbitron';
            text-shadow: 0 0 10px var(--neon-blue);
        }

        .form-subtitle {
            font-size: 13px;
            color: #999;
            font-family: 'Rajdhani';
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 600;
            color: #fff;
            font-family: 'Rajdhani';
        }

        .form-label i {
            color: var(--neon-blue);
        }

        .required-star {
            color: var(--neon-pink);
            font-weight: 900;
        }

        .form-input,
        .form-select {
            width: 100%;
            padding: 12px 15px;
            background: rgba(0, 0, 0, 0.5);
            border: 2px solid rgba(0, 243, 255, 0.3);
            border-radius: 8px;
            color: #fff;
            font-size: 14px;
            transition: all 0.3s ease;
            outline: none;
            font-family: 'Rajdhani';
            font-weight: 600;
        }

        .form-input:focus,
        .form-select:focus {
            border-color: var(--neon-blue);
            box-shadow: 0 0 15px rgba(0, 243, 255, 0.3);
            background: rgba(0, 243, 255, 0.05);
        }

        .form-input::placeholder {
            color: #666;
        }

        .form-select option {
            background: var(--bg-dark);
            color: #fff;
        }

        .form-hint {
            font-size: 12px;
            color: #999;
            margin-top: 5px;
            display: flex;
            align-items: center;
            gap: 5px;
            font-family: 'Rajdhani';
        }

        .form-hint i {
            color: var(--neon-yellow);
        }

        .discount-badge {
            display: inline-block;
            background: var(--neon-pink);
            color: #fff;
            padding: 3px 9px;
            border-radius: 11px;
            font-size: 11px;
            font-weight: 600;
            margin-left: 10px;
            font-family: 'Orbitron';
            animation: rainbowGlow 1.5s ease infinite;
        }

        .btn-purchase {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, var(--neon-blue) 0%, var(--deep-blue) 100%);
            border: none;
            border-radius: 8px;
            color: #000;
            font-size: 16px;
            font-weight: 900;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 5px 15px rgba(0, 243, 255, 0.4);
            margin-top: 20px;
            font-family: 'Orbitron';
        }

        .btn-purchase:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0, 243, 255, 0.6);
        }

        .btn-purchase:active {
            transform: translateY(-1px);
        }

        .btn-purchase i {
            margin-right: 8px;
        }

        .btn-purchase.activate-btn {
            background: linear-gradient(135deg, var(--neon-green) 0%, #2ecc71 100%);
        }

        .btn-purchase.activate-btn:hover {
            box-shadow: 0 8px 25px rgba(57, 255, 20, 0.6);
        }

        .vip-test-days {
            display: block;
            font-size: 12px;
            margin-top: 5px;
            font-weight: 600;
        }

        .help-payment-btn {
            width: 100%;
            padding: 12px;
            background: rgba(188, 19, 254, 0.2);
            border: 2px solid var(--neon-purple);
            border-radius: 8px;
            color: var(--neon-purple);
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 15px;
            font-family: 'Orbitron';
        }

        .help-payment-btn:hover {
            background: rgba(188, 19, 254, 0.3);
            transform: translateY(-2px);
        }

        .terms-text {
            font-size: 12px;
            color: #999;
            margin-top: 15px;
            text-align: center;
            line-height: 1.6;
            font-family: 'Rajdhani';
        }

        .terms-text a {
            color: var(--neon-blue);
            text-decoration: none;
        }

        .terms-text a:hover {
            text-decoration: underline;
        }

        /* === SERVER INFO SIDEBAR === */
        .server-info-card {
            background: var(--bg-glass);
            border: 2px solid var(--neon-blue);
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0, 243, 255, 0.3);
            animation: flowingNeon 5s infinite linear;
            height: fit-content;
        }

        .info-card-header {
            padding-bottom: 15px;
            border-bottom: 2px solid rgba(0, 243, 255, 0.3);
            margin-bottom: 20px;
        }

        .info-card-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--neon-blue);
            font-family: 'Orbitron';
            text-shadow: 0 0 10px var(--neon-blue);
        }

        .server-list {
            margin-bottom: 25px;
        }

        .server-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(0, 243, 255, 0.3);
            border-radius: 8px;
            margin-bottom: 10px;
            transition: all 0.3s ease;
        }

        .server-item:hover {
            background: rgba(0, 243, 255, 0.1);
            border-color: var(--neon-blue);
            transform: translateX(5px);
        }

        .server-status-indicator {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 30px;
            height: 30px;
            border-radius: 50%;
            border: 2px solid;
            transition: all 0.3s ease;
        }

        .server-status-indicator.online {
            background: var(--neon-green);
            border-color: var(--neon-green);
            animation: pulse-green 2s ease infinite;
        }

        .server-status-indicator.offline {
            background: var(--neon-red);
            border-color: var(--neon-red);
            animation: pulse-red 2s ease infinite;
        }

        .server-status-indicator.loading {
            background: #666;
            border-color: #666;
        }

        .server-details {
            flex: 1;
            margin-left: 12px;
        }

        .server-name {
            font-size: 14px;
            font-weight: 600;
            color: #fff;
            font-family: 'Rajdhani';
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .server-status-text {
            font-size: 11px;
            font-weight: 700;
            font-family: 'Orbitron';
            text-transform: uppercase;
            padding: 2px 8px;
            border-radius: 10px;
            display: inline-block;
        }

        .server-status-text.online {
            color: var(--neon-green);
            background: rgba(57, 255, 20, 0.15);
            border: 1px solid var(--neon-green);
        }

        .server-status-text.offline {
            color: var(--neon-red);
            background: rgba(255, 0, 0, 0.15);
            border: 1px solid var(--neon-red);
        }

        .server-ip {
            font-size: 12px;
            color: var(--neon-blue);
            font-family: 'Courier New', monospace;
        }

        .server-actions {
            display: flex;
            gap: 8px;
        }

        .server-btn {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(0, 243, 255, 0.3);
            border-radius: 6px;
            color: var(--neon-blue);
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .server-btn:hover {
            background: rgba(0, 243, 255, 0.2);
            border-color: var(--neon-blue);
            transform: scale(1.1);
        }

        .server-btn i {
            font-size: 14px;
        }

        /* === INFO ALERTS === */
        .info-alert {
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 15px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            animation: fadeIn 1s ease;
            border: 2px solid;
        }

        .info-alert.promo {
            background: rgba(255, 0, 110, 0.15);
            border-color: var(--neon-pink);
        }

        .info-alert.success {
            background: rgba(57, 255, 20, 0.15);
            border-color: var(--neon-green);
        }

        .info-alert.info {
            background: rgba(0, 243, 255, 0.15);
            border-color: var(--neon-blue);
        }

        .info-alert i {
            font-size: 20px;
            margin-top: 2px;
        }

        .info-alert.promo i {
            color: var(--neon-pink);
        }

        .info-alert.success i {
            color: var(--neon-green);
        }

        .info-alert.info i {
            color: var(--neon-blue);
        }

        .alert-content {
            flex: 1;
        }

        .alert-title {
            font-size: 14px;
            font-weight: 700;
            margin-bottom: 5px;
            font-family: 'Orbitron';
        }

        .alert-text {
            font-size: 13px;
            color: #ccc;
            line-height: 1.5;
            font-family: 'Rajdhani';
        }

        .alert-link {
            color: var(--neon-blue);
            text-decoration: none;
            font-weight: 600;
        }

        .alert-link:hover {
            text-decoration: underline;
        }

        /* === RECENT PURCHASES === */
        .recent-purchases {
            background: var(--bg-glass);
            border: 2px solid var(--neon-blue);
            border-radius: 12px;
            padding: 25px;
            margin-top: 30px;
            box-shadow: 0 5px 20px rgba(0, 243, 255, 0.3);
            animation: flowingNeon 5s infinite linear;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid rgba(0, 243, 255, 0.3);
        }

        .section-title {
            font-size: 20px;
            font-weight: 700;
            color: #fff;
            font-family: 'Orbitron';
        }

        .section-title i {
            color: var(--neon-blue);
            margin-right: 10px;
            text-shadow: 0 0 10px var(--neon-blue);
        }

        .purchase-table {
            width: 100%;
            border-collapse: collapse;
        }

        .purchase-table thead {
            background: rgba(0, 243, 255, 0.1);
        }

        .purchase-table th {
            padding: 12px 15px;
            text-align: left;
            font-size: 13px;
            font-weight: 700;
            color: var(--neon-blue);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid var(--neon-blue);
            font-family: 'Orbitron';
        }

        .purchase-table td {
            padding: 15px;
            border-bottom: 1px solid rgba(0, 243, 255, 0.2);
            font-size: 14px;
            font-family: 'Rajdhani';
        }

        .purchase-table tbody tr {
            transition: all 0.3s ease;
        }

        .purchase-table tbody tr:hover {
            background: rgba(0, 243, 255, 0.05);
        }

        .player-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .player-avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            border: 2px solid var(--neon-blue);
        }

        .player-name {
            font-weight: 600;
            color: #fff;
        }

        .server-badge {
            display: inline-block;
            padding: 4px 10px;
            background: rgba(0, 243, 255, 0.2);
            border: 1px solid var(--neon-blue);
            border-radius: 15px;
            font-size: 12px;
            font-weight: 600;
            color: var(--neon-blue);
            font-family: 'Orbitron';
        }

        .purchase-date {
            color: #999;
            font-size: 13px;
        }

        /* === BANNER ITEMS === */
        .list-container {
            display: flex;
            flex-direction: column;
            gap: 30px;
            margin-top: 40px;
        }

        .banner-item {
            background: rgba(0, 5, 10, 0.6);
            border: 2px solid var(--neon-blue);
            padding: 20px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 25px;
            transition: 0.3s;
            animation: flowingNeon 5s infinite linear;
        }

        .banner-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0, 243, 255, 0.3);
        }

        .banner-img {
            width: 200px;
            height: 150px;
            object-fit: cover;
            border-radius: 15px;
            border: 2px solid var(--neon-blue);
            cursor: pointer;
            transition: 0.3s;
        }

        .banner-img:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px var(--neon-blue);
        }

        .banner-info {
            flex: 1;
            text-align: left;
        }

        .banner-title {
            font-family: 'Orbitron';
            font-size: 24px;
            color: #fff;
            margin-bottom: 10px;
            text-shadow: 0 0 10px var(--neon-blue);
        }

        .banner-price {
            font-family: 'Orbitron';
            font-size: 20px;
            color: var(--neon-blue);
            font-weight: 900;
        }

        .btn-buy-now {
            background: #fff;
            color: #000;
            font-family: 'Orbitron';
            font-size: 16px;
            font-weight: 900;
            padding: 10px 25px;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: 0.3s;
            text-decoration: none;
            display: inline-block;
            animation: flowingNeon 3s infinite linear;
        }

        .btn-buy-now:hover {
            background: var(--neon-blue);
            color: #000;
            transform: scale(1.05);
        }

        /* === MODALS === */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 10000;
            backdrop-filter: blur(10px);
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal-content {
            background: var(--bg-glass);
            border: 2px solid var(--neon-blue);
            border-radius: 20px;
            padding: 30px;
            max-width: 800px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            animation: fadeIn 0.3s ease;
            box-shadow: 0 10px 40px rgba(0, 243, 255, 0.4);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid rgba(0, 243, 255, 0.3);
        }

        .modal-title {
            font-family: 'Orbitron';
            font-size: 24px;
            font-weight: 900;
            color: var(--neon-blue);
            text-shadow: 0 0 10px var(--neon-blue);
        }

        .modal-close {
            font-family: 'Orbitron';
            color: #fff;
            font-size: 30px;
            cursor: pointer;
            transition: 0.3s;
        }

        .modal-close:hover {
            color: var(--neon-pink);
            text-shadow: 0 0 15px var(--neon-pink);
            transform: rotate(90deg);
        }

        /* === NOTIFICATION === */
        .notification-box {
            position: fixed;
            top: 100px;
            right: -300px;
            background: rgba(0, 5, 20, 0.95);
            border: 2px solid var(--neon-blue);
            padding: 15px 25px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 0 30px rgba(0, 243, 255, 0.4);
            z-index: 20000;
            transition: right 0.5s ease;
            animation: flowingNeon 3s infinite linear;
        }

        .notification-box.show {
            right: 20px;
        }

        .notif-icon {
            color: var(--neon-blue);
            font-size: 20px;
            text-shadow: 0 0 10px var(--neon-blue);
        }

        .notif-text {
            font-family: 'Orbitron';
            color: #fff;
            font-size: 14px;
        }

        /* === CLIENT SECTION === */
        .client-layout {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 30px;
        }

        .client-info {
            flex: 1;
            text-align: left;
        }

        .client-desc-text {
            font-family: 'Rajdhani';
            font-size: 16px;
            color: #ccc;
            line-height: 1.8;
            margin-top: 15px;
        }

        .client-images {
            display: flex;
            gap: 20px;
        }

        .client-img-side {
            width: 250px;
            height: 180px;
            object-fit: cover;
            border-radius: 15px;
            border: 2px solid var(--neon-blue);
            cursor: pointer;
            transition: 0.3s;
        }

        .client-img-side:hover {
            transform: scale(1.05);
            box-shadow: 0 0 25px var(--neon-blue);
        }

        .btn-buy-main {
            background: #fff;
            color: #000;
            font-family: 'Orbitron';
            font-size: 24px;
            font-weight: 900;
            padding: 15px 50px;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 25px;
            text-decoration: none;
            display: inline-block;
            animation: flowingNeon 3s infinite linear;
        }

        .btn-buy-main:hover {
            background: var(--neon-blue);
            color: #000;
            transform: scale(1.15);
        }

        /* === HOME BUTTONS MODIFIED === */
        .home-btn-container {
            display: flex;
            flex-direction: column; /* Vertical alignment */
            align-items: center; /* Center content */
            gap: 35px;
            margin-top: 50px;
        }

        .btn-wrapper {
            width: 300px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .label-style {
            font-family: 'Orbitron';
            font-size: 13px;
            font-weight: bold;
            margin-bottom: 8px;
            display: block;
            min-height: 30px;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .flat-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: transparent !important;
            font-family: 'Orbitron';
            text-transform: uppercase;
            text-decoration: none;
            border: 2px solid;
            transition: all 0.3s ease;
            cursor: pointer;
            border-radius: 50px;
            font-weight: 900;
            padding: 16px 35px;
            font-size: 16px;
        }

        .btn-online-flat {
            animation: pulse-blue 2s infinite ease-in-out;
            border-color: var(--neon-blue);
            color: var(--neon-blue);
        }

        .btn-online-flat:hover {
            background: var(--neon-blue) !important;
            color: #000 !important;
        }

        .btn-vip-flat {
            animation: rainbowGlow 2s infinite ease-in-out;
            border-color: #ffffff;
            color: #ffffff;
            padding: 22px 0;
            font-size: 1.5rem; /* Larger for center */
            transform: scale(1.1);
        }

        .btn-vip-flat:hover {
            background: #ffffff !important;
            color: #000 !important;
        }

        .btn-discord-flat {
            animation: pulse-blue 2s infinite ease-in-out;
            border-color: #7289da;
            color: #7289da;
        }

        .btn-discord-flat:hover {
            background: #7289da !important;
            color: #fff !important;
        }

        .xmas-title-style {
            font-family: 'Orbitron';
            color: #fff;
            text-shadow: 0 0 10px var(--neon-blue);
        }

        .xmas-gold-style {
            font-family: 'Orbitron';
            color: var(--neon-blue);
            text-shadow: 0 0 10px var(--deep-blue);
            font-weight: 900;
        }

        /* === RESPONSIVE === */
        @media (max-width: 1200px) {
            .purchase-container {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .menu-toggle {
                display: block;
            }

            .sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s ease;
            }

            .sidebar.mobile-open {
                transform: translateX(0);
            }

            .main-content {
                margin-left: 0;
            }

            .banner-item {
                flex-direction: column;
                text-align: center;
            }

            .banner-img {
                width: 100%;
            }

            .header-announcement {
                display: none;
            }

            .client-layout {
                flex-direction: column;
            }

            .client-images {
                flex-direction: column;
            }

            .client-img-side {
                width: 100%;
            }
        }

        /* === IMAGE ZOOM === */
        #image-zoom-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 100000;
            cursor: zoom-out;
        }

        #image-zoom-overlay.active {
            display: flex;
        }

        #image-zoom-overlay img {
            max-width: 90%;
            max-height: 90%;
            border: 3px solid var(--neon-blue);
            border-radius: 10px;
            animation: flowingNeon 4s infinite linear;
        }

        .close-zoom-btn {
            position: absolute;
            top: 30px;
            right: 40px;
            font-family: 'Orbitron';
            color: #fff;
            font-size: 40px;
            font-weight: 900;
            cursor: pointer;
            text-shadow: 0 0 15px var(--neon-blue);
        }

        .error-msg {
            color: var(--neon-pink);
            font-size: 14px;
            margin-top: 10px;
            font-family: 'Orbitron';
            font-weight: 600;
            display: none;
        }

        .acc-logo {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            border: 2px solid var(--neon-blue);
            background: var(--neon-blue);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #000;
            font-weight: 900;
            font-family: 'Orbitron';
        }

        .login-input {
            width: 100%;
            padding: 12px 15px;
            background: rgba(0, 0, 0, 0.5);
            border: 2px solid rgba(0, 243, 255, 0.3);
            border-radius: 8px;
            color: #fff;
            font-size: 14px;
            transition: all 0.3s ease;
            outline: none;
            font-family: 'Rajdhani';
            font-weight: 600;
            margin-bottom: 15px;
        }

        .login-input:focus {
            border-color: var(--neon-blue);
            box-shadow: 0 0 15px rgba(0, 243, 255, 0.3);
        }

        .account-info-display {
            padding: 20px;
            background: rgba(0, 243, 255, 0.05);
            border: 2px solid var(--neon-blue);
            border-radius: 12px;
            margin-top: 20px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid rgba(0, 243, 255, 0.2);
        }

        .info-row:last-child {
            border-bottom: none;
        }

        .info-label {
            font-family: 'Orbitron';
            color: var(--neon-blue);
            font-weight: 700;
        }

        .info-value {
            font-family: 'Rajdhani';
            color: #fff;
            font-weight: 600;
        }
    </style>
</head>

