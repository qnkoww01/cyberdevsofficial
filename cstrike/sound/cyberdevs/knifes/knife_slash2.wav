                    <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid rgba(0, 243, 255, 0.2);">
                        <h4 style="font-family: 'Orbitron'; color: var(--neon-blue); margin-bottom: 15px;">Or Join Our Discord</h4>
                        <button class="btn-buy-now" onclick="window.open('https://discord.gg/95Pn9AYr3e', '_blank')">
                            <i class="fab fa-discord"></i> Join Discord Server
